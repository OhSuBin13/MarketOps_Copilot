{
  "name": "@marketops/api",
  "version": "0.1.0",
  "private": true,
  "description": "MarketOps Copilot API",
  "scripts": {
    "build": "npm run prisma:generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --runInBand",
    "prisma:validate": "cross-env DATABASE_URL=postgresql://marketops:marketops@localhost:5432/marketops?schema=public prisma validate",
    "prisma:generate": "cross-env DATABASE_URL=postgresql://marketops:marketops@localhost:5432/marketops?schema=public prisma generate",
    "prisma:migrate:dev": "cross-env DATABASE_URL=postgresql://marketops:marketops@localhost:5432/marketops?schema=public prisma migrate dev --name init"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "prisma": "^6.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "eslint": "9.27.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.18.2"
  }
}
