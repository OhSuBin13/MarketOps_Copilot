{
  "name": "marketops-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "MarketOps Copilot monorepo",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run start:dev -w apps/api",
    "start": "npm run start -w apps/api",
    "build": "npm run build -w apps/api",
    "lint": "npm run lint -w apps/api",
    "test": "npm run test -w apps/api",
    "prisma:validate": "npm run prisma:validate -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:migrate:dev": "npm run prisma:migrate:dev -w apps/api"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "@eslint/plugin-kit": "0.3.4"
  }
}
